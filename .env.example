# =============================================
# ZOO ARCADIA - CONFIGURATION
# =============================================
# En local : copier ce fichier en .env
# Sur Coolify : définir ces variables dans l'interface
# (les variables Coolify prennent le dessus sur .env)

# --- COOLIFY : réseau interne ---
# Traefik route uniquement le trafic HTTP public vers l'app (port 80).
# La BDD communique via le réseau Docker interne Coolify, PAS via Traefik.
#
# Option A (recommandée) : coller l'URL interne depuis Coolify
#   Resource MariaDB → Connection Details → Internal
#   Exemple : mysql://root:motdepasse@nom-conteneur-mariadb:3306/arcadia_db_elisabeth
# DATABASE_URL=mysql://root:password@nom-conteneur-mariadb:3306/arcadia_db_elisabeth
#
# Option B : variables séparées (DB_HOST = hostname interne du conteneur MariaDB)
DB_HOST=nom-conteneur-mariadb
DB_PORT=3306
DB_NAME=arcadia_db_elisabeth
DB_USER=root
DB_PASSWORD=

# MongoDB (optionnel — compteur de visites, à configurer plus tard)
# MONGODB_URI=mongodb+srv://user:password@cluster.example.net/ARCADIA_ZOO?retryWrites=true

# Environnement
ENVIRONMENT=production
