# =============================================
# ZOO ARCADIA - CONFIGURATION
# =============================================
# En local : copier ce fichier en .env
# Sur Coolify : définir ces variables dans l'interface
# (les variables Coolify prennent le dessus sur .env)

# MariaDB / MySQL (Coolify — réseau interne)
# DB_HOST = hostname interne du conteneur MariaDB (ex: nom du service Coolify)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arcadia_db_elisabeth
DB_USER=root
DB_PASSWORD=

# MongoDB Atlas (compteur de visites)
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/ARCADIA_ZOO?retryWrites=true

# Environnement
ENVIRONMENT=development
